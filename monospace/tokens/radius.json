{
  "radius": {
    "$type": "dimension",
    "_comment": "Soft, modern rounding — 8px is the base (--radius in the source).",
    "none": { "$value": "0rem" },
    "sm":   { "$value": "0.375rem" },
    "md":   { "$value": "0.5rem" },
    "lg":   { "$value": "0.625rem" },
    "xl":   { "$value": "0.875rem" },
    "full": { "$value": "9999px" }
  }
}
