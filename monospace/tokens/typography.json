{
  "font": {
    "family": {
      "$type": "fontFamily",
      "mono": { "$value": ["Fira Code", "ui-monospace", "SFMono-Regular", "Menlo", "Consolas", "monospace"], "$description": "Everything is monospace in this style" }
    },

    "weight": {
      "$type": "fontWeight",
      "regular":  { "$value": 400 },
      "medium":   { "$value": 500 },
      "semibold": { "$value": 600 },
      "bold":     { "$value": 700 }
    },

    "size": {
      "$type": "dimension",
      "xs":   { "$value": "0.75rem" },
      "sm":   { "$value": "0.875rem" },
      "base": { "$value": "1rem" },
      "lg":   { "$value": "1.25rem" },
      "xl":   { "$value": "1.5rem" },
      "2xl":  { "$value": "2rem" },
      "3xl":  { "$value": "2.75rem" },
      "4xl":  { "$value": "3.25rem" }
    },

    "lineHeight": {
      "$type": "number",
      "tight":  { "$value": 1.12, "$description": "Display headings" },
      "snug":   { "$value": 1.3 },
      "normal": { "$value": 1.6, "$description": "Body — roomy for monospace" }
    },

    "letterSpacing": {
      "$type": "dimension",
      "tight":  { "$value": "-0.01em" },
      "normal": { "$value": "0em" },
      "wide":   { "$value": "0.08em", "$description": "Uppercase labels / bracket tags" }
    }
  }
}
